# Copy this file to .env before running scripts manually or tests
# Values below match the docker-compose.yml defaults — no changes needed for local Docker setup

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=assessment_dw
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Used by Python scripts (ingest, transform, load, monitor) via python-dotenv
# Note: use 'postgres' as host when running inside Docker containers, 'localhost' when running locally
DATABASE_URL=postgresql://admin:admin@postgres:5432/assessment_dw

# Data path (used by ingest.py)
DATA_DIR=./data
